# Servidor
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Autenticación
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRES_IN=8h

# Base de datos (Supabase / Postgres)
# Obtenerla en supabase.com → su proyecto → Project Settings → Database →
# Connection string → pestaña "URI" (puerto 5432). Reemplace [YOUR-PASSWORD]
# por la contraseña de la base de datos que definió al crear el proyecto.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres
